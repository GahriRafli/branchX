generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_POSTGRES_URL")
}

model User {
  id                    String          @id @default(cuid())
  name                  String
  nip                   String          @unique
  password              String
  role                  String          @default("USER")
  can_access_monitoring Boolean         @default(false)
  currentSessionId      String?
  whatsapp              String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  monitoringEntries     MonitoringActivity[]
  notifications         Notification[]
  tasks                 Task[]
  leads                 Lead[]
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // GMM_ENTRY, TASK_ASSIGNED, etc.
  message     String
  referenceId String?  // ID of the related GMM/Task
  isRead      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model MonitoringActivity {
  id           String   @id @default(cuid())
  activityType String   @default("GMM")
  name         String
  codeReferral String
  product      String   @default("")
  amount       Float    @default(0)
  target       Float    @default(0)
  total       Float    @default(0)
  noAccount    String   @default("")
  ktp          String   @default("")
  branchCode   String   @default("")
  status       String   @default("PENDING")
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  sourceFile  String   @default("")
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignee    User?    @relation(fields: [assigneeId], references: [id])
}

enum LeadType {
  INTENSIFICATION
  EXTENSIFICATION
  BOTTOM_UP
}

enum LeadStatus {
  NEW
  READY_TO_FOLLOW_UP
  CONTACTED
  IN_DISCUSSION
  WAITING_CUSTOMER
  NEED_SUPPORT
  WON
  LOST
  DORMANT
  CANCELLED
  KICK
  NEED_FU
}

model Lead {
  id                   String      @id @default(cuid())
  lead_name            String
  cif                  String?
  lead_type            LeadType
  branch               String?
  potential_amount     Float       @default(0)
  owner_user_id        String?
  owner                User?       @relation(fields: [owner_user_id], references: [id])
  status               LeadStatus  @default(NEW)
  priority             String      @default("MEDIUM")
  lead_category        String?
  area                 String?
  area_name            String?
  branch_code          String?
  three_p              String?     @default("Pebisnis")
  closing_amount       Float       @default(0)
  keterangan           String?
  next_action          String?
  support_needed       String?
  last_activity_at     DateTime?
  source_upload_batch  String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  
  tasks                Task[]
}

model UploadBatch {
  id           String   @id @default(cuid())
  filename     String
  uploader_id  String
  total_rows   Int
  valid_rows   Int
  invalid_rows Int
  created_at   DateTime @default(now())
}
