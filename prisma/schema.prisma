generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_POSTGRES_URL")
}

model User {
  id                    String          @id @default(cuid())
  name                  String
  nip                   String          @unique
  password              String
  role                  String          @default("USER")
  can_access_monitoring Boolean         @default(false)
  currentSessionId      String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  monitoringEntries     MonitoringGMM[]
  notifications         Notification[]
  tasks                 Task[]
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // GMM_ENTRY, TASK_ASSIGNED, etc.
  message     String
  referenceId String?  // ID of the related GMM/Task
  isRead      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model MonitoringGMM {
  id           String   @id @default(cuid())
  name         String
  codeReferral String
  product      String
  amount       Float    @default(0)
  target       Float    @default(0)
  total        Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  noAccount    String   @default("")
  status       String   @default("PENDING")
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("TODO")
  priority    String   @default("MEDIUM")
  sourceFile  String   @default("")
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignee    User?    @relation(fields: [assigneeId], references: [id])
}
